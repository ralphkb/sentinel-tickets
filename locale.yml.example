# Close ticket embed
closeEmbed:
  color: "#FF2400"
  title: "Ticket Closed"
  description: "This ticket was closed by **{user} ({user.tag})**\nReason: **{reason}**" # Use {user} for the username of the staff, {user.tag} to have the staff tagged and {reason} for the reason
  timestamp: true
